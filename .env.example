# Velvet Food Imports — environment variable template
# Copy this file to .env and fill in real values.
# The .env file is git-ignored and must never be committed.
#
# CRITICAL: GOOGLE_SERVICE_ACCOUNT_JSON must be on ONE single line.
# python-dotenv splits multi-line values and breaks json.loads().
# Minify the JSON before pasting: remove all whitespace and newlines.
# Example of correct single-line format:
#   GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...","client_email":"..."}
#
# To minify a JSON file on macOS:
#   python3 -c "import json,sys; print(json.dumps(json.load(open('key.json'))))"

GOOGLE_SERVICE_ACCOUNT_JSON=your_single_line_json_here
GOOGLE_SHEETS_ID=your_sheets_id_here

# Path to the historical Commander xlsx (absolute or relative to repo root)
VFI_HISTORICAL_XLSX=data/historical/Korean food imports list for deer velvet.xlsx

# Optional: override MFDS data directory (default: data/mfds/)
VFI_MFDS_DIR=data/mfds
